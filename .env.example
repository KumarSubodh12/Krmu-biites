# ─── KRMU Bites — Environment Variables ──────────────────────────────────────
# Copy this file to .env for local development
# On Railway/Render/Heroku: add these in the platform dashboard

# PORT (optional — most platforms set this automatically)
# PORT=3000

# ─── MANAGER PASSWORD ─────────────────────────────────────────────────────────
# Override the manager login password via environment variable.
# This takes HIGHEST priority over the database-stored password.
# Changing this env var + restarting the app instantly changes the password.
#
# If NOT set → uses password stored in krmu_data.json (default: krmu@admin)
#
# MANAGER_PASSWORD=YourSecurePassword@123

# ─── RESET TOKEN ──────────────────────────────────────────────────────────────
# Enable the secret password-reset URL for deployment environments.
# Set this to any long random string.
#
# Once set, visit this URL in your browser to reset the manager password:
#   https://your-app.railway.app/api/auth/reset?token=YOUR_TOKEN
#
# To reset to a specific new password:
#   https://your-app.railway.app/api/auth/reset?token=YOUR_TOKEN&newpw=NewPass@123
#
# RESET_TOKEN=change_this_to_a_long_random_secret_string_abc123xyz
